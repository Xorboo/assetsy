# Copy to .env and fill in. Docker compose reads TELEGRAM_* / MONGO_DB from here;
# the MONGO_URI / SELENIUM_URL values below are for running the bot locally without
# docker (pointing at the ports exposed by `docker compose up mongo chrome`).
MONGO_URI=mongodb://localhost:27018
MONGO_DB=assetsy
SELENIUM_URL=http://localhost:4444/wd/hub

TELEGRAM_BOT_TOKEN=<telegram bot token>
TELEGRAM_ADMIN_USER_ID=<your user id>
